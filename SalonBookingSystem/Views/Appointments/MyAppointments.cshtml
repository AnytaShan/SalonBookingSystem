@model IEnumerable<SalonBookingSystem.Models.Appointment>
@{
    ViewData["Title"] = "Мои записи";
}

<h2>Мои записи</h2>
@if (!Model.Any())
{
    <p>У вас пока нет записей.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Дата и время</th>
                <th>Услуга</th>
                <th>Специалист</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var app in Model)
            {
                <tr>
                    <td>@app.StartTime.ToString("dd.MM.yyyy HH:mm") - @app.EndTime.ToString("HH:mm")</td>
                    <td>@app.Service.Name</td>
                    <td>@app.Specialist.LastName @app.Specialist.FirstName</td>
                    <td>
                        @switch (app.Status)
                        {
                            case AppointmentStatus.Confirmed:
                                <span class="badge bg-success">Подтверждена</span>
                                break;
                            case AppointmentStatus.Canceled:
                                <span class="badge bg-secondary">Отменена</span>
                                break;
                            case AppointmentStatus.Completed:
                                <span class="badge bg-info">Выполнена</span>
                                break;
                        }
                    </td>
                    <td>
                        @if (app.Status == AppointmentStatus.Confirmed && app.StartTime > DateTime.Now)
                        {
                            <form method="post" asp-action="Cancel" style="display:inline;">
                                <input type="hidden" name="id" value="@app.Id" />
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Отменить запись?')">Отменить</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}