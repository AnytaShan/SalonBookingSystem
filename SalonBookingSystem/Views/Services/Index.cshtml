@model IEnumerable<SalonBookingSystem.Models.Service>

@{
    ViewData["Title"] = "Наши услуги";
}

<h2>Наши услуги</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">@item.Name</h5>
                    <p class="card-text">@item.Description</p>
                    <p><strong>@item.Price.ToString("C")</strong></p>
                    <p>Длительность: @item.DurationMinutes мин.</p>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">Подробнее</a>
                </div>
            </div>
        </div>
    }
</div>
