@model SalonBookingSystem.Models.User
@{
    ViewData["Title"] = "Новый пользователь";
}
<h2>Создание пользователя</h2>
<form method="post">
    <div class="mb-3">
        <label asp-for="Phone">Телефон (логин)</label>
        <input asp-for="Phone" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="PasswordHash">Пароль</label>
        <input asp-for="PasswordHash" type="password" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="FirstName">Имя</label>
        <input asp-for="FirstName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="LastName">Фамилия</label>
        <input asp-for="LastName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Роль</label>
        <select asp-for="Role" class="form-control" asp-items="Html.GetEnumSelectList<UserRole>()"></select>
    </div>
    <div class="mb-3" id="specialistBlock" style="display:none;">
        <label>Специалист</label>
        <select asp-for="SpecialistId" class="form-control" asp-items="ViewBag.Specialists"><option value="">Не выбран</option></select>
    </div>
    <button class="btn btn-primary">Сохранить</button>
</form>
@section Scripts {
    <script>
        $(function() {
            $('#Role').change(function() {
                $('#specialistBlock').toggle($(this).val() === 'Specialist');
            }).change();
        });
    </script>
}