@model SalonBookingSystem.Models.User
@{
    ViewData["Title"] = "Удаление пользователя";
}

<h2>Удаление пользователя</h2>

<div class="alert alert-danger">
    <h4>Вы уверены, что хотите удалить этого пользователя?</h4>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Телефон</dt>
        <dd class="col-sm-10">@Model.Phone</dd>
        <dt class="col-sm-2">ФИО</dt>
        <dd class="col-sm-10">@Model.LastName @Model.FirstName</dd>
        <dt class="col-sm-2">Роль</dt>
        <dd class="col-sm-10">@Model.Role</dd>
        <dt class="col-sm-2">Telegram Chat ID</dt>
        <dd class="col-sm-10">@Model.TelegramChatId</dd>
    </dl>

    <form asp-action="DeleteUser" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a asp-action="Users" class="btn btn-secondary">Отмена</a>
    </form>
</div>
