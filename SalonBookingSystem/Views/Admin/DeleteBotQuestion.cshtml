@model SalonBookingSystem.Models.BotQuestion
@{
    ViewData["Title"] = "Удаление ответа бота";
}

<h2>Удаление ответа</h2>
<div class="alert alert-warning">
    <h4>Вы действительно хотите удалить этот ответ?</h4>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Ключевые слова</dt>
        <dd class="col-sm-10">@Model.Keywords</dd>
        <dt class="col-sm-2">Ответ</dt>
        <dd class="col-sm-10">@Model.Answer</dd>
        <dt class="col-sm-2">Активен</dt>
        <dd class="col-sm-10">@(Model.IsActive ? "Да" : "Нет")</dd>
    </dl>

    <form asp-action="DeleteBotQuestion" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a asp-action="BotQuestions" class="btn btn-secondary">Отмена</a>
    </form>
</div>