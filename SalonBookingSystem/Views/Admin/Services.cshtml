@model IEnumerable<SalonBookingSystem.Models.Service>
@{
    ViewData["Title"] = "Управление услугами";
}

<h2>Услуги</h2>
<p>
    <a asp-action="CreateService" class="btn btn-success">Добавить услугу</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Название</th>
            <th>Цена</th>
            <th>Длительность</th>
            <th>Активна</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price.ToString("C")</td>
                <td>@item.DurationMinutes мин.</td>
                <td>@(item.IsActive ? "Да" : "Нет")</td>
                <td>
                    <a asp-action="EditService" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Ред.</a>
                    <a asp-action="DeleteService" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>