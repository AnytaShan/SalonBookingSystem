@model IEnumerable<SalonBookingSystem.Models.User>
@{
    ViewData["Title"] = "Пользователи системы";
}

<h2>Пользователи</h2>

<p>
    <a asp-action="CreateUser" class="btn btn-success">Добавить пользователя</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Телефон (логин)</th>
            <th>ФИО</th>
            <th>Email</th>
            <th>Роль</th>
            <th>Telegram</th>
            <th>Специалист</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Phone</td>
                <td>@user.LastName @user.FirstName</td>
                <td>@user.Email</td>
                <td>@user.Role</td>
                <td>@(user.TelegramChatId == null ? "Не привязан" : "Привязан")</td>
                <td>@(user.Specialist?.LastName ?? "—")</td>
                <td>
                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Ред.</a>
                    <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>