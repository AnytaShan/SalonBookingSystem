@model SalonBookingSystem.Models.User
@{
    ViewData["Title"] = "Редактирование пользователя";
    var roles = Html.GetEnumSelectList<SalonBookingSystem.Models.UserRole>();
}

<h2>Редактирование пользователя</h2>

<form asp-action="EditUser" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Phone" class="form-label"></label>
        <input asp-for="Phone" class="form-control" />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="PasswordHash" class="form-label">Новый пароль (оставьте пустым, чтобы не менять)</label>
        <input asp-for="PasswordHash" type="password" class="form-control" />
        <span asp-validation-for="PasswordHash" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Role" class="form-label"></label>
        <select asp-for="Role" asp-items="roles" class="form-control"></select>
    </div>
    <div class="mb-3" id="specialistBlock">
        <label asp-for="SpecialistId" class="form-label">Специалист (только для роли «Специалист»)</label>
        <select asp-for="SpecialistId" class="form-control" asp-items="ViewBag.Specialists">
            <option value="">Не выбран</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="TelegramChatId" class="form-label">Telegram Chat ID</label>
        <input asp-for="TelegramChatId" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Users" class="btn btn-secondary">Отмена</a>
</form>

@section Scripts {
    <script>
        $(function() {
            function toggleSpecialist() {
                var role = $('#Role').val();
                $('#specialistBlock').toggle(role === 'Specialist');
            }
            toggleSpecialist();
            $('#Role').change(toggleSpecialist);
        });
    </script>
}